#!/bin/bash
# AppRun script for I2P+ AppImage
# This script is the entry point for the AppImage

APP="$(dirname "$(readlink -f "${0}")")"
export I2P="$APP/i2p"
export JAVA_HOME="${APP}/usr/lib/jvm/java-17-openjdk-amd64"

# Set up environment
export PATH="$JAVA_HOME/bin:$PATH"
export HOME="${HOME:-/tmp}"
export I2P_CONFIG_DIR="${HOME}/.i2p"
export I2P_LOG_DIR="${HOME}/.i2p/logs"

# Create config dir if it doesn't exist
mkdir -p "$I2P_CONFIG_DIR"

# Run I2P+
exec "$I2P/i2prouter" "$@"